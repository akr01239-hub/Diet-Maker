<?xml version="1.0" encoding="utf-8"?>
<!-- NutriAI mark: a bold "N" whose right stroke sprouts a leaf. Vector (no binary),
     so it drives the launcher icon, splash and login logo together. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- N — left vertical stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,78 L34,32 L45,32 L45,78 Z" />
    <!-- N — diagonal stroke (top-left to bottom-right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,32 L45,32 L74,78 L63,78 Z" />
    <!-- N — right vertical stroke (starts lower to make room for the leaf) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M63,78 L63,46 L74,46 L74,78 Z" />

    <!-- Leaf sprouting from the top of the right stroke -->
    <path
        android:fillColor="#4ADE80"
        android:pathData="M63,48 C62,34 72,26 84,26 C85,38 77,50 65,50 C64,50 63,49 63,48 Z" />
    <!-- Leaf vein -->
    <path
        android:fillColor="#0E7C3A"
        android:pathData="M66,47 C72,40 78,34 82,30 L83,31 C79,36 73,42 67,48 Z" />
</vector>
