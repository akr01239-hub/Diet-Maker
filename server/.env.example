# Copy to server/.env for local dev. NEVER commit the real .env.
# In production, set these in the Render dashboard (see render.yaml).

# --- Neon Postgres ---
# Pooled connection for the running app:
DATABASE_URL="postgresql://<user>:<pw>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
# Direct (non-pooled) connection for migrations:
DIRECT_URL="postgresql://<user>:<pw>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"

# --- Auth / crypto (generate strong random values) ---
JWT_ACCESS_SECRET="<64+ random chars>"
JWT_REFRESH_SECRET="<64+ random chars>"
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
HEALTH_DATA_ENCRYPTION_KEY="<32-byte base64 key>"

# --- AI (free by default) ---
AI_PROVIDER="rules"            # rules(default,no key) | ollama | gemini | groq
# OLLAMA_URL="http://localhost:11434"
# GEMINI_API_KEY=""
# GROQ_API_KEY=""

# --- Optional free integrations ---
USDA_FDC_API_KEY=""            # FREE: https://fdc.nal.usda.gov/api-key-signup
REDIS_URL=""                  # optional; empty -> in-memory fallback
GOOGLE_CLIENT_ID=""
FCM_SERVER_KEY=""
STORAGE_DRIVER="local"

# --- Server ---
PORT="8080"
NODE_ENV="development"
LOG_LEVEL="info"
CORS_ORIGINS="*"
