// NutriAI — Prisma schema.
// Phase 1: identity + encrypted health profile + versioned calc snapshots.
// Sensitive health data is stored AES-256-GCM-encrypted in `Profile.sensitiveEnc`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled — runtime
  directUrl = env("DIRECT_URL")   // direct — migrations
}

enum Role {
  user
  dietitian
  admin
}

/// Marker table proving the DB is migrated/reachable (surfaced by /ready).
model AppMeta {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("app_meta")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role     @default(user)

  dob      DateTime?
  gender   String? // 'male' | 'female' | other free text
  country  String?
  state    String?
  city     String?
  language String   @default("en")
  timezone String   @default("Asia/Kolkata")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       Profile?
  refreshTokens RefreshToken[]
  calcResults   CalcResultSnapshot[]
  auditLogs     AuditLog[]
  dietPlans     DietPlan[]
  foodLogs      FoodLog[]
  waterLogs     WaterLog[]
  checkins      WeeklyCheckin[]
  familyMembers FamilyMember[]
  exerciseLogs     ExerciseLog[]
  periodLogs       PeriodLog[]
  chatMessages     ChatMessage[]
  savedFoods       SavedFood[]
  wellnessSessions WellnessSession[]

  @@map("users")
}

/// A family member owned by a User — each has its own encrypted health profile and gets
/// its own calc/plan (a "separate AI"). Scoped to the owner via ownerId.
model FamilyMember {
  id              String   @id @default(uuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  firstName       String
  relation        String? // e.g. spouse, child, parent
  heightCm        Float
  activityLevel   String   @default("moderate")
  goal            String   @default("maintain")
  dietType        String   @default("nonveg")
  reducedMobility Boolean  @default(false)
  /// AES-256-GCM JSON: sex, dob, weights, conditions, allergies, ...
  sensitiveEnc    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId])
  @@map("family_members")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 of the opaque refresh token — the raw token is never stored.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Non-sensitive planning inputs.
  heightCm        Float
  activityLevel   String  @default("moderate")
  goal            String  @default("maintain")
  dietType        String  @default("nonveg")
  reducedMobility Boolean @default(false)

  /// AES-256-GCM JSON: weights, measurements, vitals, conditions, allergies, etc.
  sensitiveEnc String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("profiles")
}

/// Versioned snapshot of a deterministic CalcResult (bmi/bmr/tdee/macros/flags).
model CalcResultSnapshot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  result    Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("calc_results")
}

/// Food database (USDA + Indian seed). Per-100g macros; tags drive condition guardrails.
model Food {
  id              String   @id @default(uuid())
  name            String
  locale          String   @default("global")
  region          String?
  category        String // vegan | vegetarian | egg | nonveg
  mealSlots       String[]
  kcal            Float
  proteinG        Float
  carbG           Float
  fatG            Float
  fiberG          Float
  sugarG          Float    @default(0)
  sodiumMg        Float    @default(0)
  glycemicIndex   Int?
  typicalServingG Float    @default(100)
  costTier        Int      @default(2)
  tags            String[]
  allergens       String[]
  source          String   @default("seed")
  createdAt       DateTime @default(now())

  @@index([category])
  @@index([locale])
  @@map("foods")
}

/// A generated multi-day meal plan (days + the targets it was built for), stored as JSON.
model DietPlan {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      Json
  targets   Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("diet_plans")
}

/// A logged food entry. Nutrition is snapshotted so history stays stable if a Food changes.
model FoodLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedAt    DateTime @default(now())
  mealSlot    String
  foodId      String?
  foodName    String
  grams       Float
  entryMethod String   @default("text") // text | barcode | photo | voice
  kcal        Float
  proteinG    Float
  carbG       Float
  fatG        Float
  fiberG      Float
  sugarG      Float    @default(0)
  sodiumMg    Float    @default(0)
  notes       String?
  mood        String?
  hunger      Int?
  createdAt   DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("food_logs")
}

model WaterLog {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedAt DateTime @default(now())
  amountMl Int

  @@index([userId, loggedAt])
  @@map("water_logs")
}

/// A completed exercise / set the user actually performed. Powers "mark workout done",
/// today's workout log, and per-exercise progression ("last time: 40 kg × 8"). Not sensitive.
model ExerciseLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  performedAt  DateTime @default(now())
  exerciseName String
  focus        String? // muscle group / day focus, e.g. "Chest"
  sets         Int?
  reps         Int?
  weightKg     Float?
  durationMin  Int? // for cardio / timed work
  kcal         Int? // estimated calories burned (server-computed, MET-based)
  notes        String?
  createdAt    DateTime @default(now())

  @@index([userId, performedAt])
  @@index([userId, exerciseName])
  @@map("exercise_logs")
}

/// A completed mind-&-body session (yoga flow, meditation or breathing). Powers the
/// wellness streak and the calorie connection for the Move › Meditation sub-tab.
model WellnessSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // yoga | meditation | breathing
  refId       String // yoga flow / meditation content id
  refName     String
  durationMin Int
  kcal        Int      @default(0) // server-computed, MET-based
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, completedAt])
  @@map("wellness_sessions")
}

/// A logged menstrual period (start, optional end). The cycle engine self-calibrates
/// cycle length from the gaps between starts to estimate the current phase.
model PeriodLog {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, startDate])
  @@map("period_logs")
}

/// Persisted coach chat so the AI has memory across sessions. Content is not medical data;
/// stored plain and capped/read as a recent window.
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'assistant'
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("chat_messages")
}

/// A user's saved / custom food (per-100g). Powers favourites and create-your-own for fast logging.
model SavedFood {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  kcal      Float
  proteinG  Float    @default(0)
  carbG     Float    @default(0)
  fatG      Float    @default(0)
  fiberG    Float    @default(0)
  sugarG    Float    @default(0)
  sodiumMg  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_foods")
}

/// Weekly progress check-in. Weight + body measurements are AES-256-GCM-encrypted in
/// `measurementsEnc`; subjective 1–5 ratings are stored plain.
model WeeklyCheckin {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  measurementsEnc String? // { weightKg, waistCm?, chestCm?, hipCm?, ... }
  energy          Int? // 1..5
  sleepHours      Float?
  mood            Int? // 1..5
  pain            Int? // 1..5
  notes           String?
  createdAt       DateTime @default(now())

  @@index([userId, date])
  @@map("weekly_checkins")
}

/// Audit trail for access to health data (required by SECURITY.md).
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("audit_logs")
}
