# Root convenience copy. The server reads server/.env — see server/.env.example.
# Duplicate the values there for local dev, and set them in the Render dashboard for prod.

# Neon (Neon console -> Connection string). Pooled for app, direct for migrations.
DATABASE_URL="postgresql://<user>:<pw>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
DIRECT_URL="postgresql://<user>:<pw>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"

JWT_ACCESS_SECRET="<64+ random chars>"
JWT_REFRESH_SECRET="<64+ random chars>"
HEALTH_DATA_ENCRYPTION_KEY="<32-byte base64 key>"

AI_PROVIDER="rules"            # rules(default,no key) | ollama | gemini | groq
# OLLAMA_URL="http://localhost:11434"
# GEMINI_API_KEY=""
# GROQ_API_KEY=""

USDA_FDC_API_KEY=""            # FREE: https://fdc.nal.usda.gov/api-key-signup
REDIS_URL=""                  # optional; empty -> in-memory fallback
GOOGLE_CLIENT_ID=""           # free
FCM_SERVER_KEY=""             # free tier
STORAGE_DRIVER="local"        # free local disk in dev
CORS_ORIGINS="*"

PORT="8080"
NODE_ENV="development"
LOG_LEVEL="info"
